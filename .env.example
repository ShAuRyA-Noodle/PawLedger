# PawLedger environment variables
# Copy to .env and fill in real values. Never commit a filled-in .env.
# Keys prefixed NEXT_PUBLIC_ are exposed to the browser; keep everything
# else server-only. See docs/LAUNCH_CHECKLIST.md for where each is obtained.

# --- Core ---
# Public base URL of the deployment (used for links, OG, sitemap, auth).
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Comma-separated extra trusted origins for auth (optional).
TRUSTED_ORIGINS=

# --- Database (Postgres / Neon) ---
DATABASE_URL=postgres://user:password@host:5432/pawledger

# --- Auth (Better Auth) ---
# Generate a strong random secret, e.g. `openssl rand -base64 32`.
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# --- Payments: Razorpay (India) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Public key id used by the checkout widget in the browser.
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# --- Payments: Stripe (US) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM=PawLedger <hello@pawledger.org>

# --- Rate limiting / cache (Upstash Redis) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Analytics (PostHog, EU region) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# --- Notifications / ops ---
ADMIN_EMAIL=admin@pawledger.org
SOS_ADMIN_EMAIL=sos@pawledger.org
CSR_LEAD_EMAIL=csr@pawledger.org
